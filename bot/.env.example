# ──────────────────────────────────────────────────────────────
# Variables de entorno del bot (Railway en producción)
# Copiá este archivo como .env para desarrollo local
# NUNCA commitear el .env con valores reales
# ──────────────────────────────────────────────────────────────

# Token del bot de Telegram (obtenido desde @BotFather)
TELEGRAM_BOT_TOKEN=REEMPLAZAR_CON_TU_BOT_TOKEN

# URL pública del servicio en Railway (ej: https://mi-bot.up.railway.app)
# Dejar vacío para que el bot use polling en desarrollo local
TELEGRAM_WEBHOOK_URL=

# Tu chat_id numérico de Telegram
# Para obtenerlo: mandá un mensaje a @userinfobot en Telegram
ALLOWED_TELEGRAM_USER_ID=REEMPLAZAR_CON_TU_CHAT_ID

# Google AI Studio API Key
# Obtenerla en: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=REEMPLAZAR_CON_TU_GOOGLE_API_KEY

# Supabase
# Encontrás estos valores en: Project Settings → API
SUPABASE_URL=REEMPLAZAR_CON_TU_SUPABASE_URL
SUPABASE_SERVICE_ROLE_KEY=REEMPLAZAR_CON_TU_SERVICE_ROLE_KEY
